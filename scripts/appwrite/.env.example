# Copia este archivo a .env y completa los valores.
# Project settings → API keys → Create (scopes: databases.*, storage.*, users.read)

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=tu_project_id
APPWRITE_API_KEY=tu_api_key_con_scopes_completos

# Opcional: IDs fijos (no cambies si ya corriste el script)
APPWRITE_DATABASE_ID=nexus_campus
